import { Theme } from "theme.slint";

// A Path fed Rust-built `commands`, mapped 1:1 from a design-space viewbox.
export component PathBox inherits Rectangle {
    in property <string> commands;
    in property <brush> fill: transparent;
    in property <brush> stroke: transparent;
    in property <length> sw: 1px;
    in property <length> vbw;
    in property <length> vbh;
    Path {
        width: 100%; height: 100%;
        viewbox-width: root.vbw / 1px; viewbox-height: root.vbh / 1px;
        commands: root.commands; fill: root.fill; stroke: root.stroke; stroke-width: root.sw;
    }
}

export component SectionLabel inherits HorizontalLayout {
    in property <string> text;
    spacing: 7px;
    VerticalLayout {
        alignment: center;
        Rectangle { width: 5px; height: 5px; border-radius: 2.5px; background: Theme.amber; }
    }
    Text { text: root.text; font-family: Theme.mono; font-size: 11px; font-weight: 700; color: Theme.muted; letter-spacing: 1.4px; vertical-alignment: center; }
}

export component AmberButton inherits Rectangle {
    in property <string> text;
    callback clicked();
    height: 42px;
    horizontal-stretch: 0;
    background: ta.pressed ? Theme.amber-press : (ta.has-hover ? Theme.amber-bright : Theme.amber);
    border-radius: 10px;
    animate background { duration: 100ms; }
    HorizontalLayout {
        padding-left: 26px;
        padding-right: 26px;
        Text { text: root.text; color: Theme.ink; font-size: 13px; font-weight: 600; vertical-alignment: center; }
    }
    ta := TouchArea {
        mouse-cursor: pointer; clicked => { root.clicked(); } }
}

export component QuitButton inherits Rectangle {
    callback clicked();
    height: 42px;
    horizontal-stretch: 0;
    background: ta.pressed ? rgba(232,137,111,0.18) : (ta.has-hover ? rgba(232,137,111,0.08) : transparent);
    border-radius: 10px;
    border-width: 1px;
    border-color: ta.has-hover ? rgba(232,137,111,0.6) : rgba(232,137,111,0.35);
    animate background, border-color { duration: 100ms; }
    HorizontalLayout {
        padding-left: 18px;
        padding-right: 18px;
        Text { text: "Quit Sundial"; color: Theme.danger; font-size: 13px; font-weight: 600; vertical-alignment: center; }
    }
    ta := TouchArea {
        mouse-cursor: pointer; clicked => { root.clicked(); } }
}

export component GhostButton inherits Rectangle {
    in property <string> text;
    callback clicked();
    horizontal-stretch: 0;
    height: 28px;
    width: lay.preferred-width;
    background: ta.has-hover ? rgba(255,255,255,0.06) : transparent;
    border-radius: 7px;
    animate background { duration: 100ms; }
    lay := HorizontalLayout {
        padding-left: 12px; padding-right: 12px;
        Text { text: root.text; color: ta.has-hover ? Theme.muted : Theme.faint; font-size: 12px;
            vertical-alignment: center; animate color { duration: 100ms; } }
    }
    ta := TouchArea {
        mouse-cursor: pointer; clicked => { root.clicked(); } }
}

export component Checkbox inherits HorizontalLayout {
    in property <string> text;
    in-out property <bool> checked;
    callback toggled(bool);
    spacing: 10px;
    Rectangle {
        width: 18px; height: 18px; border-radius: 5px;
        y: parent.height / 2 - 9px;
        background: root.checked ? Theme.amber : rgba(255,255,255,0.04);
        border-width: root.checked ? 0px : 1px;
        border-color: rgba(255,255,255,0.18);
        Path {
            width: 18px; height: 18px; viewbox-width: 18; viewbox-height: 18;
            visible: root.checked;
            commands: "M 4 9.5 L 7.5 13 L 14 5.5";
            stroke: Theme.ink; stroke-width: 2.2px; fill: transparent;
        }
        TouchArea {
        mouse-cursor: pointer; clicked => { root.checked = !root.checked; root.toggled(root.checked); } }
    }
    Text { text: root.text; color: Theme.text; font-size: 13.5px; vertical-alignment: center; }
}

export component Toggle inherits HorizontalLayout {
    in property <string> text;
    in-out property <bool> on;
    callback toggled(bool);
    spacing: 10px;
    Rectangle {
        width: 38px; height: 22px; border-radius: 11px;
        y: parent.height / 2 - 11px;
        background: root.on ? Theme.amber : rgba(255,255,255,0.12);
        Rectangle {
            width: 18px; height: 18px; border-radius: 9px;
            y: 2px; x: root.on ? 18px : 2px;
            background: root.on ? Theme.ink : #cfc7bb;
            animate x { duration: 160ms; easing: ease; }
        }
        TouchArea {
        mouse-cursor: pointer; clicked => { root.on = !root.on; root.toggled(root.on); } }
    }
    Text { text: root.text; color: Theme.muted; font-size: 13.5px; vertical-alignment: center; }
}

export component MiniSlider inherits Rectangle {
    in property <float> minimum: 0;
    in property <float> maximum: 100;
    in-out property <float> value;
    in property <bool> enabled: true;
    callback changed();
    height: 18px;
    horizontal-stretch: 1;
    property <float> frac: (root.value - root.minimum) / (root.maximum - root.minimum);
    Rectangle { // track
        y: parent.height / 2 - 2px; height: 4px; border-radius: 2px;
        background: rgba(255,255,255,0.1);
        Rectangle { // fill
            x: 0; width: parent.width * root.frac; height: parent.height;
            border-radius: 2px; background: Theme.amber;
        }
    }
    Rectangle { // thumb
        width: 16px; height: 16px; border-radius: 8px; background: white;
        y: parent.height / 2 - 8px;
        x: (root.width - 16px) * root.frac;
        drop-shadow-blur: 4px; drop-shadow-color: rgba(0,0,0,0.4);
    }
    ta := TouchArea {
        mouse-cursor: pointer;
        enabled: root.enabled;
        function update() {
            root.value = clamp(root.minimum + (self.mouse-x / root.width) * (root.maximum - root.minimum), root.minimum, root.maximum);
            root.changed();
        }
        pointer-event(e) => { if (e.kind == PointerEventKind.down) { self.update(); } }
        moved => { if (self.pressed) { self.update(); } }
    }
}

// Custom field on TextInput so focus/selection use the amber theme and the
// suffix sits inside reserved right padding (no Fluent magenta, no clipping).
export component NumField inherits Rectangle {
    in property <string> suffix;
    in-out property <string> text;
    callback edited(string);
    height: 36px;
    background: rgba(255,255,255,0.04);
    border-width: 1px;
    border-color: ti.has-focus ? Theme.amber : rgba(255,255,255,0.09);
    border-radius: 9px;
    ti := TextInput {
        x: 11px; width: parent.width - 44px; height: 100%;
        text <=> root.text;
        color: Theme.text; font-family: Theme.mono; font-size: 14px;
        vertical-alignment: center;
        single-line: true;
        selection-background-color: Theme.amber;
        selection-foreground-color: Theme.ink;
        edited => { root.edited(self.text); }
    }
    Text {
        text: root.suffix; color: Theme.faint; font-family: Theme.mono; font-size: 12px;
        x: parent.width - 30px; width: 24px; height: 100%; vertical-alignment: center;
    }
}
