import { Theme } from "theme.slint";
import { Backend } from "backend.slint";

component WindowButton inherits Rectangle {
    in property <string> glyph;       // path commands in a 46 x 38 viewbox
    in property <bool> danger: false;
    callback clicked();
    width: 46px;
    background: ta.has-hover ? (root.danger ? #c4291f : rgba(255,255,255,0.08)) : transparent;
    animate background { duration: 80ms; }
    Path {
        width: 100%; height: 100%; viewbox-width: 46; viewbox-height: 38;
        commands: root.glyph;
        stroke: (ta.has-hover && root.danger) ? white : Theme.muted;
        stroke-width: 1.1px; fill: transparent;
    }
    ta := TouchArea { mouse-cursor: pointer; clicked => { root.clicked(); } }
}

export component TitleBar inherits Rectangle {
    height: 38px;
    background: Theme.bg;
    // drag region (sits under the icon/title; window buttons are on top).
    // We track the grab offset and feed deltas to Rust, which repositions the
    // window — staying inside Slint's event loop so the pointer grab releases
    // cleanly (a native modal move loop would swallow the mouse-up).
    drag := TouchArea {
        mouse-cursor: default;
        property <length> px;
        property <length> py;
        pointer-event(e) => {
            if (e.kind == PointerEventKind.down) { self.px = self.mouse-x; self.py = self.mouse-y; }
        }
        moved => {
            if (self.pressed) {
                Backend.win_drag_move((self.mouse-x - self.px) / 1px, (self.mouse-y - self.py) / 1px);
            }
        }
    }
    HorizontalLayout {
        padding-left: 12px;
        spacing: 9px;
        VerticalLayout {
            alignment: center;
            Image { source: @image-url("../assets/png/sundial-32.png"); width: 18px; height: 18px; }
        }
        VerticalLayout {
            alignment: center;
            Text { text: "HDR Sundial"; font-family: Theme.display; font-size: 12px; font-weight: 600; color: Theme.muted;
                letter-spacing: 0.3px; }
        }
        Rectangle { horizontal-stretch: 1; }
        // window controls
        WindowButton { glyph: "M 18 19 L 28 19"; clicked => { Backend.win_minimize(); } }
        WindowButton { danger: true; glyph: "M 18 14 L 28 24 M 28 14 L 18 24";
            clicked => { Backend.win_close(); } }
    }
}
