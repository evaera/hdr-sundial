import { Theme } from "theme.slint";
import { Backend } from "backend.slint";
import { PathBox } from "widgets.slint";

// Side-on protractor: two-knob range (ramp-start .. full-daylight) over the
// horizon, with a live sun dot. Design space 276 x 176 maps 1:1 to px.
export component ElevationArc inherits Rectangle {
    width: 276px; height: 176px;
    // faint horizon baseline from O to the right edge
    Rectangle { x: 26px; y: 94px; width: parent.width - 26px - 4px; height: 1px; background: rgba(255,255,255,0.08); }
    // filled bands
    PathBox { vbw: 276px; vbh: 176px; commands: Backend.arc_base; fill: rgba(255,255,255,0.025); }
    PathBox { vbw: 276px; vbh: 176px; commands: Backend.arc_night; fill: rgba(34,44,82,0.6); }
    Path { width: 100%; height: 100%; viewbox-width: 276; viewbox-height: 176;
        commands: Backend.arc_ramp;
        fill: @linear-gradient(180deg, rgba(247,177,60,0.9) 0%, rgba(51,65,122,0.75) 100%); }
    PathBox { vbw: 276px; vbh: 176px; commands: Backend.arc_day; fill: rgba(247,177,60,0.16); }
    // outer arc edge, notches, horizon ray
    PathBox { vbw: 276px; vbh: 176px; commands: Backend.arc_edge; stroke: rgba(255,255,255,0.18); sw: 1.25px; }
    PathBox { vbw: 276px; vbh: 176px; commands: Backend.arc_notch_minor; stroke: rgba(255,255,255,0.2); sw: 1px; }
    PathBox { vbw: 276px; vbh: 176px; commands: Backend.arc_notch_major; stroke: rgba(255,255,255,0.4); sw: 1px; }
    PathBox { vbw: 276px; vbh: 176px; commands: Backend.arc_horizon; stroke: rgba(255,255,255,0.5); sw: 1.25px; }
    // observer dot at O = (26, 94)
    Rectangle { width: 5px; height: 5px; border-radius: 2.5px; background: rgba(255,255,255,0.65);
        x: 26px - 2.5px; y: 94px - 2.5px; }
    // 0deg label just outside the horizon ray; po(0) = (174, 94)
    Text { text: "0\u{b0}"; font-family: Theme.mono; font-size: 9px; color: Theme.faint2; letter-spacing: 0.4px; x: 174px + 9px; y: 94px - 7px; }
    // live sun: radial glow + disc
    Rectangle { width: 40px; height: 40px; border-radius: 20px;
        x: Backend.arc_sun_x * 1px - 20px; y: Backend.arc_sun_y * 1px - 20px;
        background: @radial-gradient(circle, rgba(255,212,121,0.55) 0%, rgba(255,180,63,0.25) 45%, rgba(255,180,63,0) 72%); }
    Rectangle { width: 11px; height: 11px; border-radius: 5.5px; background: Theme.sun;
        x: Backend.arc_sun_x * 1px - 5.5px; y: Backend.arc_sun_y * 1px - 5.5px;
        border-width: 0.75px; border-color: rgba(255,255,255,0.5); }
    // knob rays (inner → outer)
    Path { width: 100%; height: 100%; viewbox-width: 276; viewbox-height: 176;
        commands: "M " + Backend.arc_rs_ix + " " + Backend.arc_rs_iy + " L " + Backend.arc_rs_x + " " + Backend.arc_rs_y;
        stroke: rgba(255,255,255,0.22); stroke-width: 1px; }
    Path { width: 100%; height: 100%; viewbox-width: 276; viewbox-height: 176;
        commands: "M " + Backend.arc_fd_ix + " " + Backend.arc_fd_iy + " L " + Backend.arc_fd_x + " " + Backend.arc_fd_y;
        stroke: rgba(255,255,255,0.22); stroke-width: 1px; }
    // knobs: white disc with amber ring
    Rectangle { width: 15px; height: 15px; border-radius: 7.5px; background: white;
        border-width: 3px; border-color: Theme.amber;
        x: Backend.arc_rs_x * 1px - 7.5px; y: Backend.arc_rs_y * 1px - 7.5px; }
    Rectangle { width: 15px; height: 15px; border-radius: 7.5px; background: white;
        border-width: 3px; border-color: Theme.amber;
        x: Backend.arc_fd_x * 1px - 7.5px; y: Backend.arc_fd_y * 1px - 7.5px; }
    // value pills (offset +12px right of each knob)
    Rectangle { background: rgba(10,8,6,0.62); border-width: 1px; border-color: rgba(255,255,255,0.12);
        border-radius: 7px; height: 18px; width: t_rs.preferred-width + 12px;
        x: Backend.arc_rs_x * 1px + 12px; y: Backend.arc_rs_y * 1px - 9px;
        t_rs := Text { text: Backend.arc_rs_pill; font-family: Theme.mono; font-size: 12px; font-weight: 600; color: Theme.text;
            x: 6px; height: 100%; vertical-alignment: center; } }
    Rectangle { background: rgba(10,8,6,0.62); border-width: 1px; border-color: rgba(255,255,255,0.12);
        border-radius: 7px; height: 18px; width: t_fd.preferred-width + 12px;
        x: Backend.arc_fd_x * 1px + 12px; y: Backend.arc_fd_y * 1px - 9px;
        t_fd := Text { text: Backend.arc_fd_pill; font-family: Theme.mono; font-size: 12px; font-weight: 600; color: Theme.text;
            x: 6px; height: 100%; vertical-alignment: center; } }
    // legend (bottom-left)
    HorizontalLayout {
        x: 0; y: 158px; height: 16px; spacing: 16px;
        HorizontalLayout { spacing: 6px;
            VerticalLayout { alignment: center; Rectangle { width: 9px; height: 9px; border-radius: 2.5px; background: #3a4a80; } }
            Text { text: "Ramp start"; font-size: 11px; color: Theme.muted; vertical-alignment: center; }
            Text { text: Backend.arc_rs_pill; font-family: Theme.mono; font-size: 11px; font-weight: 600; color: Theme.text; vertical-alignment: center; }
        }
        HorizontalLayout { spacing: 6px;
            VerticalLayout { alignment: center; Rectangle { width: 9px; height: 9px; border-radius: 2.5px; background: Theme.amber; } }
            Text { text: "Full daylight"; font-size: 11px; color: Theme.muted; vertical-alignment: center; }
            Text { text: Backend.arc_fd_pill; font-family: Theme.mono; font-size: 11px; font-weight: 600; color: Theme.text; vertical-alignment: center; }
        }
    }
    // drag: pick the nearer knob on press, then track elevation angle from O
    ta := TouchArea {
        mouse-cursor: pointer;
        property <bool> rs;
        function ang() -> float { Math.atan2(94 - self.mouse-y / 1px, self.mouse-x / 1px - 26) / 1deg }
        function dsq(kx: float, ky: float) -> float {
            (self.mouse-x / 1px - kx) * (self.mouse-x / 1px - kx) + (self.mouse-y / 1px - ky) * (self.mouse-y / 1px - ky)
        }
        function apply() { if (self.rs) { Backend.set_ramp(self.ang()); } else { Backend.set_daylight(self.ang()); } }
        pointer-event(e) => {
            if (e.kind == PointerEventKind.down) {
                self.rs = self.dsq(Backend.arc_rs_x, Backend.arc_rs_y) <= self.dsq(Backend.arc_fd_x, Backend.arc_fd_y);
                self.apply();
            }
        }
        moved => { if (self.pressed) { self.apply(); } }
    }
}
