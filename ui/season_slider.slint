import { Theme } from "theme.slint";
import { Backend } from "backend.slint";

// A subtle day-of-year scrubber: dragging overrides the declination so the
// whole brightness model re-derives for that time of year. Reset is owned by
// the NOW header (it clears both time and season).
export component SeasonRow inherits VerticalLayout {
    spacing: 5px;
    HorizontalLayout {
        Text { text: "SEASON"; font-family: Theme.mono; font-size: 11px; font-weight: 500; color: Theme.muted; letter-spacing: 0.5px; }
        Rectangle { horizontal-stretch: 1; }
        Text { text: Backend.season_date; font-family: Theme.mono; font-size: 11px; font-weight: 600; color: Theme.text; }
    }
    Rectangle {
        height: 16px;
        // season gradient — warm peak follows the hemisphere (lat sign)
        Rectangle {
            y: parent.height / 2 - 2px; height: 4px; border-radius: 2px;
            opacity: 0.45;
            background: Backend.lat < 0
                ? @linear-gradient(90deg, Theme.amber 0%, #586394 25%, #33417a 47%, #586394 72%, Theme.amber 100%)
                : @linear-gradient(90deg, #33417a 0%, #586394 22%, Theme.amber 47%, #586394 73%, #33417a 100%);
        }
        // solstice / equinox notches (day-of-year 80, 172, 266, 355)
        for m in [80, 172, 266, 355] : Rectangle {
            width: 1px; height: 8px; y: parent.height / 2 - 4px;
            x: parent.width * m / 364 - 0.5px;
            background: rgba(255,255,255,0.22);
        }
        // 'today' dot (green) on the year track
        Rectangle {
            width: 4px; height: 4px; border-radius: 2px; background: Theme.live;
            x: parent.width * Backend.today_doy / 364 - 2px; y: parent.height / 2 - 2px;
        }
        // thumb
        Rectangle {
            width: 12px; height: 12px; border-radius: 6px; background: white;
            x: (parent.width - 12px) * Backend.season_doy / 364; y: parent.height / 2 - 6px;
            drop-shadow-blur: 3px; drop-shadow-color: rgba(0,0,0,0.5);
        }
        ta := TouchArea {
            mouse-cursor: pointer;
            function set() { Backend.set_season(Math.round(clamp(self.mouse-x / parent.width, 0, 1) * 364)); }
            pointer-event(e) => { if (e.kind == PointerEventKind.down) { self.set(); } }
            moved => { if (self.pressed) { self.set(); } }
        }
    }
}
